# Groq API Key for LLM
GROQ_API_KEY=your_groq_api_key_here

# Kaggle Credentials (Required if you want to re-run the downloader/indexer)
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_key

# Database URL (Default for development)
DATABASE_URL=sqlite+aiosqlite:///backend/backend/app/data/nyaya_vaani.db

# Redis URL (For Celery worker)
REDIS_URL=redis://localhost:6379/0
